  "_说明": {
    "版本": "1.1",
    "用途": "户外徒步记录数据文件",
    "更新方式": "每次新增徒步，在 trips 数组末尾复制一份完整的对象，修改其中的值即可",
    "图片路径": "建议统一放在 photos/ 文件夹下，按路线名称建子文件夹，例如 photos/badaling/cover.jpg",
    "difficulty 可选值": ["初级", "中级", "高级"],
    "season 可选值": ["春", "夏", "秋", "冬"],
    "新增字段说明": {
      "avg_speed_kmh": "平均速度，单位 km/h，可从运动手表或 App 导出",
      "best_pace_per_km": "最快配速，格式 mm:ss，例如 6:30 表示每公里最快 6 分 30 秒",
      "avg_heart_rate_bpm": "平均心率，单位 bpm（次/分钟），需要心率设备记录",
      "elevation_gain_m": "累积上升，单位 米，徒步中所有上坡段的总爬升高度",
      "elevation_loss_m": "累积下降，单位 米，徒步中所有下坡段的总下降高度",
      "calories_kcal": "卡路里消耗，单位 kcal（大卡），可从运动手表或 App 导出"
    }
  },

